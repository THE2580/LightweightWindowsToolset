{
  "name": "lightweight-windows-toolset",
  "version": "1.2.1",
  "description": "轻量化 Windows 桌面工具集",
  "author": "THE2580",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "npm run build && electron-builder --win --dir",
    "package:nsis": "npm run build && electron-builder --win",
    "test:e2e": "node tests/run-e2e.js"
  },
  "build": {
    "appId": "com.lightweight.toolset",
    "productName": "轻量化工具集",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "resources/**/*"
    ],
    "asar": true,
    "win": {
      "target": {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      },
      "icon": "resources/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "轻量化工具集",
      "installerIcon": "resources/icon.ico",
      "uninstallerIcon": "resources/icon.ico",
      "installerHeaderIcon": "resources/icon.ico",
      "language": "2052"
    },
    "extraResources": [
      {
        "from": "resources/",
        "to": "resources/",
        "filter": [
          "*.ico",
          "*.png"
        ]
      },
      {
        "from": "resources/pinman.exe",
        "to": "pinman.exe"
      },
      {
        "from": "resources/keystats.exe",
        "to": "keystats.exe"
      },
      {
        "from": "resources/appstats.exe",
        "to": "appstats.exe"
      }
    ]
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^8.2.0",
    "framer-motion": "^12.0.0",
    "lucide-react": "^0.460.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "screenshot-desktop": "^1.15.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^5.0.0",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "@playwright/test": "^1.60.0"
  }
}
